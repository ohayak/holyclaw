{
  "meta": {
    "lastTouchedVersion": "2026.3.23",
    "lastTouchedAt": "2026-03-29T08:10:38.614Z"
  },
  "env": {
    "shellEnv": {
      "enabled": true
    },
    "vars": {}
  },
  "wizard": {
    "lastRunAt": "2026-02-24T10:10:49.395Z",
    "lastRunVersion": "2026.2.22-2",
    "lastRunCommand": "doctor",
    "lastRunMode": "local"
  },
  "update": {
    "channel": "stable",
    "checkOnStart": false
  },
  "browser": {
    "enabled": true,
    "remoteCdpTimeoutMs": 8000,
    "remoteCdpHandshakeTimeoutMs": 10000,
    "defaultProfile": "headless",
    "profiles": {
      "headless": {
        "cdpUrl": "${HEADLESS_CDP_URL}",
        "color": "#ff750e"
      },
      "headfull": {
        "cdpUrl": "${HEADFULL_CDP_URL}",
        "color": "#22C55E"
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "cliproxy": {
        "baseUrl": "${CLIPROXY_BASE_URL}",
        "apiKey": "${CLIPROXY_API_KEY}",
        "api": "openai-completions",
        "models": []
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "cliproxy/claude-opus-4-6",
        "fallbacks": [
          "cliproxy/claude-sonnet-4-6"
        ]
      },
      "models": {
        "cliproxy/claude-opus-4-6": {
          "params": { "context1m" : true }
        }
      },
      "memorySearch": {
        "sources": [
          "memory",
          "sessions"
        ],
        "experimental": {
          "sessionMemory": true
        },
        "model": "cliproxy/claude-haiku-4-5",
        "store": {
          "vector": {
            "enabled": true
          }
        },
        "query": {
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.7,
            "textWeight": 0.3,
            "candidateMultiplier": 4,
            "mmr": {
              "enabled": true,
              "lambda": 0.7
            },
            "temporalDecay": {
              "enabled": true,
              "halfLifeDays": 30
            }
          }
        },
        "cache": {
          "enabled": true,
          "maxEntries": 50000
        }
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h",
        "keepLastAssistants": 3,
        "softTrimRatio": 0.3,
        "hardClearRatio": 0.5,
        "minPrunableToolChars": 50000,
        "softTrim": {
          "maxChars": 4000,
          "headChars": 1500,
          "tailChars": 1500
        },
        "hardClear": {
          "enabled": true,
          "placeholder": "[old tool result content cleared]"
        }
      },
      "compaction": {
        "reserveTokensFloor": 20000,
        "model": "cliproxy/claude-haiku-4-5",
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 4000,
          "prompt": "Write any lasting notes to memory/YYYY-MM-DD.md; reply with NO_REPLY if nothing to store.",
          "systemPrompt": "Session nearing compaction. Store durable memories now."
        }
      },
      "heartbeat": {
        "every": "55m",
        "model": "cliproxy/claude-haiku-4-5",
        "lightContext": true
      },
      "thinkingDefault": "medium",
      "typingMode": "thinking",
      "subagents": {
        "maxConcurrent": 8,
        "maxSpawnDepth": 3,
        "maxChildrenPerAgent": 8,
        "model": "cliproxy/claude-sonnet-4-6",
        "runTimeoutSeconds": 3600
      }
    },
    "list": [
      {
        "id": "main",
        "name": "main",
        "workspace": "${HOME}/.openclaw/workspaces/main",
        "model": "cliproxy/claude-opus-4-6",
        "identity": {
          "name": "main",
          "theme": "Second brain",
          "emoji": "🧠"
        },
        "tools": {
          "profile": "full"
        }
      }
    ]
  },
  "tools": {
    "allow": [],
    "alsoAllow": [
      "lobster"
    ],
    "web": {
      "search": {
        "enabled": true
      }
    },
    "agentToAgent": {
      "enabled": true
    },
    "exec": {
      "security": "full",
      "ask": "off"
    }
  },
  "bindings": [],
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "bash": true,
    "restart": true,
    "ownerDisplay": "raw"
  },
  "approvals": {
    "exec": {
      "enabled": true,
      "agentFilter": [
        "`[\"main\"]`"
      ]
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "hooks": {
    "token": "hooks_${OPENCLAW_GATEWAY_TOKEN}"
  },
  "channels": {
    "whatsapp": {
      "enabled": false,
      "dmPolicy": "pairing",
      "selfChatMode": true,
      "allowFrom": [],
      "groupAllowFrom": [],
      "groupPolicy": "allowlist",
      "debounceMs": 0,
      "mediaMaxMb": 50
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "custom",
    "customBindHost": "0.0.0.0",
    "controlUi": {
      "allowedOrigins": [
        "*"
      ],
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true
    },
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "trustedProxies": [
      "127.0.0.1/32"
    ],
    "remote": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "memory": {
    "backend": "builtin",
    "citations": "auto"
  },
  "skills": {
    "entries": {
      "coding-agent": {
        "enabled": true
      }
    }
  },
  "plugins": {
    "enabled": true,
    "allow": [
      "discord",
      "memory-core"
    ],
    "load": {
      "paths": []
    },
    "entries": {
      "whatsapp": {
        "enabled": false
      },
      "discord": {
        "enabled": true
      },
      "imessage": {
        "enabled": false
      },
      "telegram": {
        "enabled": false
      },
      "slack": {
        "enabled": false
      },
      "nostr": {
        "enabled": false
      },
      "signal": {
        "enabled": false
      },
      "googlechat": {
        "enabled": false
      },
      "memory-core": {
        "enabled": true
      },
      "llm-task": {
        "enabled": true
      }
    }
  }
}
